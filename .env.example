# ==========================================
# Gmail MCP
# ==========================================
# Obtener en Google Cloud Console → APIs y servicios → Credenciales
# Documentación: integrations/gmail/README.md
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ==========================================
# Google Drive MCP
# ==========================================
# Obtener en Google Cloud Console → APIs y servicios → Credenciales
# Documentación: integrations/google-drive/README.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Folder ID de la carpeta raíz del emprendimiento en Google Drive
# Obtener de la URL: https://drive.google.com/drive/folders/ESTE_ES_EL_ID
GOOGLE_FOLDER_ID=

# ==========================================
# WhatsApp MCP
# ==========================================
# Opción recomendada: Meta WhatsApp Business API
# Alternativa: Twilio (ver integrations/whatsapp/README.md)
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# ==========================================
# Google Calendar MCP
# ==========================================
# Calendar ID del emprendimiento
# Usar "primary" para el calendario principal
# O usar el ID específico: abc123@group.calendar.google.com
CALENDAR_ID=primary

# ==========================================
# Instagram MCP
# ==========================================
# Token de acceso de Instagram
INSTAGRAM_TOKEN=
INSTAGRAM_CUENTA_ID=

# ==========================================
# Google Analytics
# ==========================================
# Tracking ID de Google Analytics
GOOGLE_ANALYTICS_TRACKING_ID=
